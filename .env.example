# Example environment for `docker compose up` of the Metis gateway.
# Copy to `.env` and fill in the keys you actually use.

# At least one provider key is required for the gateway to make real LLM
# calls. The CLI smoke (`metis gateway`) starts with zero keys; outbound
# calls fail at the adapter with `auth_error` until a key is set.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# Override the gateway listen port (default 8422).
# METIS_GATEWAY_PORT=8422

# Override the global-default model (used when routing finds no other slot win).
# METIS_GATEWAY_GLOBAL_DEFAULT=anthropic:claude-sonnet-4-6

# Path on the host to expose into the container as /workspace. The gateway
# does not write to the workspace (per-request stateless), but `metis gateway
# issue-key --workspace …` records the path with the key for attribution.
# METIS_WORKSPACE=./
