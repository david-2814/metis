---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

// Comparison facts. Sourced from docs/market-research/03-routing-layers.md,
// a 2026-05-16 GitHub spot-check for public repo counts, plus our own
// shipped feature inventory in AGENTS.md. Every "no" is justified by a
// documented gap; every "yes" is something we've live-validated.

const competitors = ["LiteLLM", "Portkey", "Helicone", "Metis"];

const rows = [
  {
    section: "Wire fidelity",
    items: [
      {
        feature: "OpenAI Chat shape inbound",
        cells: ["yes", "yes", "yes", "yes"],
      },
      {
        feature: "Anthropic Messages shape inbound",
        cells: ["partial", "partial", "passthrough", "yes"],
      },
      {
        feature: "Lossless thinking / reasoning blocks",
        cells: [
          "no (#27512 open)",
          "lossy on convert",
          "passthrough only",
          "yes",
        ],
      },
      {
        feature: "Lossless tool_use round-trip",
        cells: [
          "regressions (#27469)",
          "normalized",
          "passthrough only",
          "yes",
        ],
      },
      {
        feature: "cache_control preserved end-to-end",
        cells: ["bug-of-the-week", "lossy", "passthrough only", "yes"],
      },
      {
        feature: "Replays survive provider wire changes",
        cells: [
          "no (logs are wire-format)",
          "no",
          "no",
          "yes (canonical IR)",
        ],
      },
    ],
  },
  {
    section: "Routing",
    items: [
      {
        feature: "Manual / configured rules",
        cells: ["yes", "yes (conditional)", "light", "yes (yaml policy)"],
      },
      {
        feature: "Per-request override (model in body)",
        cells: ["yes", "yes", "yes", "yes"],
      },
      {
        feature: "Pattern-learned routing from outcomes",
        cells: ["no", "no", "no", "yes (slot 4, K-NN)"],
      },
      {
        feature: "Planner-worker delegation as a tool",
        cells: ["no", "no", "no", "yes (delegate())"],
      },
      {
        feature: "Capability validation pre-dispatch",
        cells: ["partial", "partial", "no", "yes (per-model)"],
      },
    ],
  },
  {
    section: "Cost attribution",
    items: [
      {
        feature: "Per-key cost rollup",
        cells: ["yes", "yes", "yes", "yes"],
      },
      {
        feature: "Per-user / per-team rollup",
        cells: ["per req/user", "per req/team", "per user/session", "yes"],
      },
      {
        feature: "Cost-per-quality (evaluator joined)",
        cells: ["no", "no", "no", "yes"],
      },
      {
        feature: "Baseline counterfactual (savings_pct)",
        cells: ["no", "no", "no", "yes"],
      },
      {
        feature: "Prompt cache hit-rate per model",
        cells: ["partial", "partial", "yes", "yes"],
      },
    ],
  },
  {
    section: "Quality signal",
    items: [
      {
        feature: "Built-in evaluator (heuristic + LLM judge)",
        cells: ["no", "no", "no", "yes (hybrid)"],
      },
      {
        feature: "Per-turn / per-session / per-workload verdicts",
        cells: ["no", "no", "no", "yes"],
      },
      {
        feature: "Budget-capped LLM judging",
        cells: ["no", "no", "no", "yes ($0.10/session, $1/day)"],
      },
    ],
  },
  {
    section: "Compliance",
    items: [
      {
        feature: "Audit log (key lifecycle + policy events)",
        cells: ["no", "yes (SaaS)", "yes (SaaS)", "yes (12-event)"],
      },
      {
        feature: "GDPR export / forget endpoints",
        cells: ["no", "vendor-managed", "vendor-managed", "yes"],
      },
      {
        feature: "Trace retention sweep with audit exemption",
        cells: ["no", "vendor-managed", "vendor-managed", "yes (90-day)"],
      },
      {
        feature: "Export redaction (4 modes)",
        cells: ["no", "no", "no", "yes"],
      },
      {
        feature: "SOC2 gap audit published",
        cells: ["no", "Type 2", "Type 2", "Type 1 Q3 2026"],
      },
    ],
  },
  {
    section: "Deployment",
    items: [
      {
        feature: "Self-host (BYO infra)",
        cells: ["yes", "limited", "via base URL", "yes"],
      },
      {
        feature: "Helm chart published",
        cells: ["community", "no", "no", "yes"],
      },
      {
        feature: "Docker compose recipe",
        cells: ["yes", "no", "no", "yes"],
      },
      {
        feature: "Local dev mode (no cloud control plane)",
        cells: ["yes", "no", "limited", "yes"],
      },
      {
        feature: "Prometheus /metrics endpoint",
        cells: ["plugin", "vendor-managed", "vendor-managed", "yes"],
      },
    ],
  },
];

// Tone the cell so a buyer eye can pick out "yes" rows fast.
const tone = (cell: string) => {
  const c = cell.toLowerCase();
  if (c.startsWith("yes")) return "text-accent";
  if (c === "no" || c.startsWith("no ")) return "text-fg-dim";
  return "text-amber";
};
---

<Layout
  title="Metis vs LiteLLM, Portkey, Helicone — comparison | 2sum AI"
  description="One-page comparison of Metis (from 2sum AI) against the three commodity LLM gateway / routing layers."
>
  <div
    class="pointer-events-none fixed inset-0 grid-bg opacity-60 [mask-image:radial-gradient(ellipse_at_center,black_30%,transparent_75%)]"
  >
  </div>

  <div class="relative">
    <Nav current="compare" />

    <section class="mx-auto max-w-6xl px-6 pb-12 pt-20">
      <p class="prompt-before mb-3 text-sm text-fg-muted">
        <span class="text-fg">diff metis competitors/</span>
      </p>
      <h1
        class="max-w-4xl text-3xl font-bold leading-[1.15] tracking-tight sm:text-4xl md:text-5xl"
      >
        Metis vs LiteLLM,
        <br class="hidden sm:block" />
        Portkey, and Helicone.
      </h1>
      <p
        class="mt-6 max-w-3xl text-base leading-relaxed text-fg-muted sm:text-lg"
      >
        The commodity gateways intercept HTTP and proxy it. Metis runs
        the same canonical IR through the gateway and through the agent
        loop, with a pattern store that learns from outcomes and an
        evaluator that scores them. The features that show up green
        below are the moat &mdash; not the table-stakes rows above
        them.
      </p>
      <p class="mt-3 max-w-3xl text-xs text-fg-dim">
        Sourced from docs/market-research/03-routing-layers.md and a
        2026-05-16 GitHub spot-check. Tracking compiled against LiteLLM
        47.2k stars, Portkey 11.7k, and Helicone 5.7k; re-verify before
        quoting externally.
      </p>
    </section>

    <!-- COMPARISON TABLE -->
    <section class="mx-auto max-w-6xl px-6 pb-20">
      <div
        class="overflow-hidden rounded-lg border border-border bg-bg-card"
      >
        <div class="overflow-x-auto">
          <table class="w-full text-left text-sm">
            <thead class="border-b border-border-strong bg-bg-elev">
              <tr>
                <th class="px-4 py-3 font-bold text-fg-muted sm:px-6">
                  capability
                </th>
                {
                  competitors.map((c) => (
                    <th
                      class={
                        "px-4 py-3 text-center font-bold sm:px-6 " +
                        (c === "Metis"
                          ? "bg-accent/10 text-accent"
                          : "text-fg-muted")
                      }
                    >
                      {c}
                    </th>
                  ))
                }
              </tr>
            </thead>
            <tbody>
              {
                rows.map((section) => (
                  <>
                    <tr class="border-t border-border bg-bg-elev/40">
                      <td
                        colspan={competitors.length + 1}
                        class="px-4 py-2 font-mono text-xs uppercase tracking-wider text-fg-muted sm:px-6"
                      >
                        {section.section}
                      </td>
                    </tr>
                    {section.items.map((row) => (
                      <tr class="border-t border-border">
                        <td class="px-4 py-3 text-fg sm:px-6">
                          {row.feature}
                        </td>
                        {row.cells.map((cell, i) => (
                          <td
                            class={
                              "px-4 py-3 text-center sm:px-6 " +
                              tone(cell) +
                              (competitors[i] === "Metis"
                                ? " bg-accent/5"
                                : "")
                            }
                          >
                            {cell}
                          </td>
                        ))}
                      </tr>
                    ))}
                  </>
                ))
              }
            </tbody>
          </table>
        </div>
      </div>

      <p class="mt-4 text-xs text-fg-dim">
        Legend: <span class="text-accent">green</span> = shipped /
        live-validated; <span class="text-amber">amber</span> = partial
        or vendor-managed; <span class="text-fg-dim">dim</span> = not
        available.
      </p>
    </section>

    <!-- WHEN METIS WINS / DOESN'T -->
    <section class="border-t border-border bg-bg-elev/40">
      <div class="mx-auto max-w-6xl px-6 py-20">
        <div class="grid gap-10 md:grid-cols-2">
          <div>
            <h2 class="text-2xl font-bold tracking-tight sm:text-3xl">
              Pick Metis when&hellip;
            </h2>
            <ul class="mt-6 space-y-3 text-sm">
              <li class="flex items-start gap-3">
                <span class="mt-0.5 text-accent" aria-hidden="true">+</span>
                <span class="text-fg">
                  Your workloads mix easy and hard turns and you want the
                  router to learn which is which.
                </span>
              </li>
              <li class="flex items-start gap-3">
                <span class="mt-0.5 text-accent" aria-hidden="true">+</span>
                <span class="text-fg">
                  You use Anthropic thinking blocks, cache_control, or
                  tool_use heavily and can't afford the LiteLLM
                  bug-of-the-week.
                </span>
              </li>
              <li class="flex items-start gap-3">
                <span class="mt-0.5 text-accent" aria-hidden="true">+</span>
                <span class="text-fg">
                  Your buyer story needs per-team cost attribution,
                  audit log, and a SOC2 roadmap &mdash; not just "we
                  cache calls."
                </span>
              </li>
              <li class="flex items-start gap-3">
                <span class="mt-0.5 text-accent" aria-hidden="true">+</span>
                <span class="text-fg">
                  You want fan-out turns to spawn planner + worker
                  sessions, with cost attributed to the role rather
                  than just the model.
                </span>
              </li>
            </ul>
          </div>
          <div>
            <h2 class="text-2xl font-bold tracking-tight sm:text-3xl">
              Pick a commodity gateway when&hellip;
            </h2>
            <ul class="mt-6 space-y-3 text-sm">
              <li class="flex items-start gap-3">
                <span class="mt-0.5 text-fg-dim" aria-hidden="true">&minus;</span>
                <span class="text-fg-muted">
                  Single-model workloads &mdash; every turn already needs
                  the same model. Slot 4 can't find a cheaper
                  alternative. Caching saves ~22% on long sessions;
                  routing saves ~0%.
                </span>
              </li>
              <li class="flex items-start gap-3">
                <span class="mt-0.5 text-fg-dim" aria-hidden="true">&minus;</span>
                <span class="text-fg-muted">
                  Very short sessions (under ~6 turns) rarely cross the
                  cache-write break-even &mdash; the cache discipline
                  pays off later, not first call.
                </span>
              </li>
              <li class="flex items-start gap-3">
                <span class="mt-0.5 text-fg-dim" aria-hidden="true">&minus;</span>
                <span class="text-fg-muted">
                  No quality signal at all &mdash; no rubric, no test
                  suite, no human feedback. The evaluator has nothing
                  to learn from; pattern store still tracks cost and
                  latency, but success-aware routing needs a verdict.
                </span>
              </li>
              <li class="flex items-start gap-3">
                <span class="mt-0.5 text-fg-dim" aria-hidden="true">&minus;</span>
                <span class="text-fg-muted">
                  You want a fully-hosted control plane and don't mind
                  vendor lock-in on observability. Metis is a runtime
                  you operate; LiteLLM Cloud / Portkey / Helicone are
                  SaaS dashboards over your traffic.
                </span>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="border-t border-border">
      <div class="mx-auto max-w-3xl px-6 py-20 text-center">
        <h2 class="text-2xl font-bold tracking-tight sm:text-3xl">
          Run the comparison on your own traffic.
        </h2>
        <p class="mx-auto mt-4 max-w-xl text-fg-muted">
          The customer trial recipe drops the gateway in front of your
          existing tools, runs your prompts, and reports cost,
          cost-per-quality, and the routing chain trace for every turn.
          Setup is 60-90 minutes; smoke real-API spend is under $1.
        </p>
        <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
          <a
            href="/signup"
            class="inline-flex items-center gap-2 rounded border border-accent bg-accent px-5 py-3 text-sm font-bold text-bg transition-colors hover:bg-accent/90"
          >
            start a buyer trial
            <span aria-hidden="true">&rarr;</span>
          </a>
          <a
            href="/"
            class="inline-flex items-center gap-2 rounded border border-border-strong bg-bg-card px-5 py-3 text-sm font-bold text-fg transition-colors hover:border-accent"
          >
            back to overview
          </a>
        </div>
      </div>
    </section>

    <Footer />
  </div>
</Layout>
