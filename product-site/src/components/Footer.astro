---
// Shared site footer. Status-page link is the operational one;
// docs/operations links live in the repo, not on the marketing site.
---

<footer class="border-t border-border">
  <div
    class="mx-auto flex max-w-6xl flex-col items-start justify-between gap-4 px-6 py-8 text-xs text-fg-dim sm:flex-row sm:items-center"
  >
    <div class="flex items-center gap-2">
      <span class="text-accent">&gt;_</span>
      <span>metis &mdash; local-first AI dev agent</span>
    </div>
    <div class="flex flex-wrap items-center gap-x-6 gap-y-2">
      <a href="/compare" class="hover:text-fg-muted">compare</a>
      <a href="/pricing" class="hover:text-fg-muted">pricing</a>
      <a
        href="https://status.2sum.ai"
        rel="noopener"
        class="hover:text-fg-muted"
      >
        status
      </a>
      <a
        href="https://github.com/2sumAI/metis"
        rel="noopener"
        class="hover:text-fg-muted"
      >
        github
      </a>
      <span>&copy; 2026</span>
    </div>
  </div>
</footer>
