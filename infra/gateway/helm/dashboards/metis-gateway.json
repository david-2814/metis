{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus datasource scraping the Metis gateway /metrics endpoint.",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Operational dashboard for the Metis gateway — LLM latency, error rate, routing decisions, gateway auth posture, per-key cost attribution. Companion to docs/operations/observability-runbook.md.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "title": "Observability runbook",
      "url": "https://github.com/2sumAI/metis/blob/main/docs/operations/observability-runbook.md",
      "icon": "doc",
      "tags": [],
      "targetBlank": true,
      "type": "link"
    },
    {
      "title": "Incident response",
      "url": "https://github.com/2sumAI/metis/blob/main/docs/operations/incident-response.md",
      "icon": "doc",
      "tags": [],
      "targetBlank": true,
      "type": "link"
    }
  ],
  "liveNow": false,
  "panels": [
    {
      "type": "row",
      "title": "Traffic & Latency",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "id": 100,
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "LLM calls per second (by provider/model/status)",
      "id": 1,
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 1},
      "targets": [
        {
          "expr": "sum by (provider, model, status) (rate(metis_llm_calls_total[5m]))",
          "legendFormat": "{{provider}}/{{model}} ({{status}})",
          "refId": "A"
        }
      ],
      "options": {
        "legend": {"calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom"},
        "tooltip": {"mode": "multi"}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": {"mode": "palette-classic"}
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "LLM call latency — p50 / p95 / p99 (seconds)",
      "id": 2,
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 1},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(metis_llm_call_latency_seconds_bucket[5m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(metis_llm_call_latency_seconds_bucket[5m])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(metis_llm_call_latency_seconds_bucket[5m])))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "options": {
        "legend": {"calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom"},
        "tooltip": {"mode": "multi"}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": {"mode": "palette-classic"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": null, "color": "green"},
              {"value": 5, "color": "yellow"},
              {"value": 30, "color": "red"}
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "row",
      "title": "Errors",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 9},
      "id": 101,
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "LLM error rate (errors / all calls, by provider/model)",
      "id": 3,
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 10},
      "targets": [
        {
          "expr": "sum by (provider, model) (rate(metis_llm_call_errors_total[5m])) / sum by (provider, model) (rate(metis_llm_calls_total[5m]))",
          "legendFormat": "{{provider}}/{{model}}",
          "refId": "A"
        }
      ],
      "options": {
        "legend": {"calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom"},
        "tooltip": {"mode": "multi"}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": {"mode": "palette-classic"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": null, "color": "green"},
              {"value": 0.05, "color": "red"}
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "LLM errors by class (failures / sec)",
      "id": 4,
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 10},
      "targets": [
        {
          "expr": "sum by (error_class) (rate(metis_llm_call_errors_total[5m]))",
          "legendFormat": "{{error_class}}",
          "refId": "A"
        }
      ],
      "options": {
        "legend": {"calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom"},
        "tooltip": {"mode": "multi"}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "color": {"mode": "palette-classic"}
        },
        "overrides": []
      }
    },
    {
      "type": "row",
      "title": "Routing & Tools",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 18},
      "id": 102,
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Routing decisions per second (by winning slot)",
      "id": 5,
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 19},
      "targets": [
        {
          "expr": "sum by (winning_slot) (rate(metis_routing_decisions_total[5m]))",
          "legendFormat": "{{winning_slot}}",
          "refId": "A"
        }
      ],
      "options": {
        "legend": {"calcs": ["mean"], "displayMode": "table", "placement": "bottom"},
        "tooltip": {"mode": "multi"}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": {"mode": "palette-classic"}
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Tool call p95 latency (seconds, by tool)",
      "id": 6,
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 19},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (tool_name, le) (rate(metis_tool_call_latency_seconds_bucket[5m])))",
          "legendFormat": "{{tool_name}}",
          "refId": "A"
        }
      ],
      "options": {
        "legend": {"calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom"},
        "tooltip": {"mode": "multi"}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": {"mode": "palette-classic"}
        },
        "overrides": []
      }
    },
    {
      "type": "row",
      "title": "Gateway Auth & Cost",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 27},
      "id": 103,
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Gateway auth failures per second (by reason)",
      "id": 7,
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 28},
      "targets": [
        {
          "expr": "sum by (reason) (rate(metis_gateway_auth_failures_total[5m]))",
          "legendFormat": "{{reason}}",
          "refId": "A"
        }
      ],
      "options": {
        "legend": {"calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom"},
        "tooltip": {"mode": "multi"}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "color": {"mode": "palette-classic"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": null, "color": "green"},
              {"value": 0.1, "color": "red"}
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Per-gateway-key spend ($/hour, top 10)",
      "id": 8,
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 28},
      "targets": [
        {
          "expr": "topk(10, sum by (gateway_key_id) (rate(metis_gateway_key_cost_usd_total{gateway_key_id!=\"null\"}[1h]) * 3600))",
          "legendFormat": "{{gateway_key_id}}",
          "refId": "A"
        }
      ],
      "options": {
        "legend": {"calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom"},
        "tooltip": {"mode": "multi"}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "color": {"mode": "palette-classic"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": null, "color": "green"},
              {"value": 10, "color": "red"}
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "row",
      "title": "Quotas & Active Keys",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 36},
      "id": 104,
      "collapsed": false,
      "panels": []
    },
    {
      "type": "stat",
      "title": "Active gateway keys",
      "id": 9,
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 5, "w": 6, "x": 0, "y": 37},
      "targets": [
        {
          "expr": "metis_gateway_keys_active",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "graphMode": "area",
        "colorMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [{"value": null, "color": "green"}]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "Revoked / grace-expired keys",
      "id": 10,
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 5, "w": 6, "x": 6, "y": 37},
      "targets": [
        {
          "expr": "metis_gateway_keys_revoked",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "graphMode": "area",
        "colorMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [{"value": null, "color": "blue"}]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Per-identity quota ratio (used / cap)",
      "id": 11,
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 37},
      "targets": [
        {
          "expr": "metis_quota_used_ratio",
          "legendFormat": "{{identity_kind}}={{identity_id}}",
          "refId": "A"
        }
      ],
      "options": {
        "legend": {"calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom"},
        "tooltip": {"mode": "multi"}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": null, "color": "green"},
              {"value": 0.8, "color": "yellow"},
              {"value": 1.0, "color": "red"}
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Trace-DB WAL size (bytes)",
      "id": 12,
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 5, "w": 12, "x": 0, "y": 42},
      "targets": [
        {
          "expr": "metis_trace_wal_bytes",
          "legendFormat": "wal_bytes",
          "refId": "A"
        }
      ],
      "options": {
        "legend": {"calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom"},
        "tooltip": {"mode": "single"}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": {"mode": "palette-classic"}
        },
        "overrides": []
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["metis", "gateway", "observability"],
  "templating": {"list": []},
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "Metis Gateway",
  "uid": "metis-gateway-overview",
  "version": 1,
  "weekStart": ""
}
